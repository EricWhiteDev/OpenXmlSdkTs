{
  "name": "openxmlsdkts-workspace",
  "workspaces": [
    "OpenXmlSdkTs",
    "OpenXmlSdkTs.Test",
    "Examples"
  ],
  "scripts": {
    "build": "npm run build -w OpenXmlSdkTs",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint 'OpenXmlSdkTs/src/**/*.ts' 'OpenXmlSdkTs.Test/src/**/*.ts'",
    "format": "prettier --write 'OpenXmlSdkTs/src/**/*.ts' 'OpenXmlSdkTs.Test/src/**/*.ts'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
