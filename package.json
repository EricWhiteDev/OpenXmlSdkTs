{
  "name": "openxmlsdkts",
  "version": "1.0.6",
  "description": "Open XML SDK for TypeScript — read, write, and manipulate Office Open XML documents (docx, xlsx, pptx)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "workspaces": [
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "docs": "typedoc",
    "prepare": "husky"
  },
  "keywords": [
    "openxml",
    "docx",
    "xlsx",
    "pptx",
    "word",
    "excel",
    "powerpoint",
    "office",
    "ooxml"
  ],
  "author": {
    "name": "Eric White",
    "email": "eric@ericwhite.com",
    "url": "https://www.ericwhite.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricWhiteDev/OpenXmlSdkTs.git"
  },
  "homepage": "https://github.com/EricWhiteDev/OpenXmlSdkTs#readme",
  "bugs": {
    "url": "https://github.com/EricWhiteDev/OpenXmlSdkTs/issues"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "ltxmlts": "^1.0.9"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jszip": "^3.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.0.0"
  }
}
